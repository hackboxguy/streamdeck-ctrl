{
  "device": {
    "brightness": 80,
    "reconnect_timeout_sec": 0,
    "reconnect_interval_sec": 2
  },
  "notification": {
    "type": "unix_socket",
    "socket_path": "/run/streamdeck-ctrl/notify.sock",
    "state_persist_path": "{INSTALL_DIR}/state.json"
  },
  "keys": [
    {
      "position": [0, 0],
      "label": "Home",
      "icon_type": "static",
      "icons": {
        "default": "home.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/launch-home.sh",
          "async": true
        }
      }
    },
    {
      "position": [0, 1],
      "label": "Media Player",
      "icon_type": "static",
      "icons": {
        "default": "kodi.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/launch-media-player.sh",
          "async": true
        }
      }
    },
    {
      "position": [0, 2],
      "label": "Slideshow",
      "icon_type": "static",
      "icons": {
        "default": "slideshow.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/launch-slideshow.sh",
          "async": true
        }
      }
    },
    {
      "position": [0, 3],
      "label": "Video Loop",
      "icon_type": "toggle",
      "icons": {
        "on": "video-loop-on.bmp",
        "off": "video-loop-off.bmp"
      },
      "initial_state": "off",
      "notification_id": "display.video_loop",
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/video-loop-toggle.sh {state}",
          "async": true
        }
      }
    },
    {
      "position": [0, 4],
      "label": "Display Settings",
      "icon_type": "static",
      "icons": {
        "default": "settings.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/launch-disp-settings.sh",
          "async": true
        }
      }
    },
    {
      "position": [1, 0],
      "label": "Brightness Up",
      "icon_type": "static",
      "icons": {
        "default": "brightness-up.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/brightness-up.sh",
          "async": false
        }
      }
    },
    {
      "position": [1, 1],
      "label": "Brightness Down",
      "icon_type": "static",
      "icons": {
        "default": "brightness-down.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/brightness-down.sh",
          "async": false
        }
      }
    },
    {
      "position": [1, 2],
      "label": "ALS Adaptive",
      "icon_type": "toggle",
      "icons": {
        "on": "als-adaptive-on.bmp",
        "off": "als-adaptive-off.bmp"
      },
      "initial_state": "off",
      "notification_id": "display.als_adaptive",
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/als-adaptive-toggle.sh {state}",
          "async": true
        }
      }
    },
    {
      "position": [1, 3],
      "label": "Local Dimming",
      "icon_type": "toggle",
      "icons": {
        "on": "local-dimming-on.bmp",
        "off": "local-dimming-off.bmp"
      },
      "initial_state": "off",
      "notification_id": "display.local_dimming",
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/local-dimming-toggle.sh {state}",
          "async": true
        }
      }
    },
    {
      "position": [1, 4],
      "label": "Cluster Demo",
      "icon_type": "static",
      "icons": {
        "default": "cluster-demo.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/launch-cluster-demo.sh",
          "async": true
        }
      }
    },
    {
      "position": [2, 0],
      "label": "HDMI 12.3-nq1",
      "icon_type": "static",
      "icons": {
        "default": "12-3-nq1.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/apply-hdmi-12-3-nq1.sh",
          "async": true
        }
      }
    },
    {
      "position": [2, 1],
      "label": "HDMI 15.6-2k5",
      "icon_type": "static",
      "icons": {
        "default": "15-6-2k5.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/apply-hdmi-15-6-2k5.sh",
          "async": true
        }
      }
    },
    {
      "position": [2, 2],
      "label": "HDMI 14.6-fhd",
      "icon_type": "static",
      "icons": {
        "default": "14-6-fhd.bmp"
      },
      "action": {
        "on_press": {
          "type": "script",
          "command": "{INSTALL_DIR}/screens/display-control/scripts/apply-hdmi-14-6-fhd.sh",
          "async": true
        }
      }
    }
  ]
}
